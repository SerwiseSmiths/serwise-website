# ================================
# Serwise Website — Environment Variables Template
# Copy to .env.local for local dev and fill in values
# ================================

# Which environment is active: local | pre-prod | production
APP_ENV=local

# ── Backend API ───────────────────────────────────────────
# Server-side only (not exposed to browser)
BACKEND_API_URL=http://localhost:4000/api/v2

# ── Strapi CMS ────────────────────────────────────────────
# Server-side only
STRAPI_API_URL=http://localhost:1337
STRAPI_API_TOKEN=your_strapi_api_token_here

# ── Truecaller Business (waitlist notification) ───────────
# Server-side only
TRUECALLER_BUSINESS_CLIENT_ID=your_truecaller_client_id
TRUECALLER_BUSINESS_CLIENT_SECRET=your_truecaller_client_secret
